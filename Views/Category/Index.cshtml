@model IEnumerable<E_ShoppingManagement.Models.Category>

@{
    ViewData["Title"] = "Categories";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_EmployeeLayout.cshtml";
}

<h2 class="mb-3">Category List</h2>

<div class="page-card p-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">All Categories</h5>
        <a asp-action="Create" class="btn btn-primary">
            Create New Category
        </a>
    </div>

    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-header">
            <tr>
                <th style="width:70px;">Category ID</th>
                <th style="width:90px;">Image</th>
                <th>Name</th>
                <th>Status</th>
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var i = 1;
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-muted">No categories found.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="~/images/categories/@item.ImageUrl"
                                     alt="@item.Name"
                                     style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px; border: 1px solid #ddd;" />
                            }
                            else
                            {
                                <span class="text-muted small">N/A</span>
                            }
                        </td>
                        <td class="text-start fw-bold">@item.Name</td>
                        <td>
                            <span class="badge @(item.Status == "Active" ? "badge-status-active" : "badge-status-inactive")">
                                @item.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary me-1">View</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-success me-1">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>
