@model List<string>
@{
    ViewData["Title"] = "Manage Banners";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h1 class="mt-4">Manage Homepage Banners</h1>
    
    <div class="card mb-4 mt-4">
        <div class="card-header">
            <i class="fas fa-upload me-1"></i>
            Upload New Banner
        </div>
        <div class="card-body">
            <form asp-action="UploadBanner" method="post" enctype="multipart/form-data">
                <div class="input-group mb-3">
                    <input type="file" name="bannerImage" class="form-control" id="inputGroupFile02" accept="image/*" required>
                    <button class="btn btn-primary" type="submit">Upload</button>
                </div>
                <small class="text-muted">Recommended size: 1920x600 px</small>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-images me-1"></i>
            Current Banners
        </div>
        <div class="card-body">
             @if (Model != null && Model.Any())
            {
                <div class="row">
                    @foreach (var banner in Model)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <img src="~/images/banners/@banner" class="card-img-top" alt="Banner" style="height: 150px; object-fit: cover;">
                                <div class="card-body">
                                    <p class="card-text text-truncate">@banner</p>
                                    <form asp-action="DeleteBanner" method="post" onsubmit="return confirm('Are you sure you want to delete this banner?');">
                                        <input type="hidden" name="fileName" value="@banner" />
                                        <button type="submit" class="btn btn-danger btn-sm w-100">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p>No banners uploaded yet.</p>
            }
        </div>
    </div>
</div>
