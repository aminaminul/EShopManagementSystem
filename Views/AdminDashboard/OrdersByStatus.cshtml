@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    ViewData["Title"] = ViewBag.Status + " Orders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewBag.Status Orders</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
</div>

<div class="page-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Employee</th>
                    <th>Delivery Man</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                        <td>
                            @order.Customer?.Name<br />
                            <small class="text-muted">@order.PhoneNumber</small>
                        </td>
                        <td>
                            @foreach (var item in order.OrderDetails ?? new List<OrderDetails>())
                            {
                                <small>@item.Product?.Name x @item.Quantity</small><br />
                            }
                        </td>
                        <td>৳ @order.TotalAmount</td>
                        <td>
                            <span class="badge @(order.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">@order.PaymentStatus</span><br />
                            <small>@order.PaymentMethod</small>
                        </td>
                        <td>@(order.AssignedEmployee?.Name ?? "Unassigned")</td>
                        <td>@(order.DeliveryMan?.Name ?? "Unassigned")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-controller="Order" asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-success">Edit</a>
                                <a asp-controller="Order" asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
