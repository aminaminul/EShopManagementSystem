@model E_ShoppingManagement.Models.FooterInfo
@{
    ViewData["Title"] = "Footer Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Update Footer Information</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
</div>

<div class="page-card" style="max-width: 600px;">
    <form asp-action="FooterSettings" method="post">
        <div class="mb-3">
            <label class="form-label">Address</label>
            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Contact Number</label>
                <input asp-for="ContactNumber" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Facebook URL</label>
            <input asp-for="FacebookUrl" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Instagram URL</label>
            <input asp-for="InstagramUrl" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Twitter URL</label>
            <input asp-for="TwitterUrl" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
</div>
