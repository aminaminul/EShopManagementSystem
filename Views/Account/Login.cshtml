@using E_ShoppingManagement.ViewModels
@model LoginViewModel;

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="login-bg">
    <div class="login-box">
        <h2 class="mb-4 text-center">Welcome Back</h2>
        <p class="text-center mb-4 small">Please login to your account</p>
        
        <form asp-action="Login" method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold text-white">Email Address</label>
                <input asp-for="Email" class="form-control login-input" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-warning small float-start"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold text-white">Password</label>
                <div class="position-relative password-container">
                    <input asp-for="Password" type="password" class="form-control login-input" placeholder="Enter your password" />
                    <i class="bi bi-eye password-toggle eye-icon"></i>
                </div>
                <span asp-validation-for="Password" class="text-warning small float-start"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 mt-4">
                <div class="form-check mb-0">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label small text-white">Remember Me</label>
                </div>
                <a asp-controller="Account" asp-action="VerifyEmail" class="small text-decoration-none text-white">Forgot Password?</a>
            </div>

            <input type="submit" value="Login" class="btn btn-login w-100 mb-3 fw-bold py-2 rounded" />

            <div class="text-center mt-4">
                <p class="small mb-1 text-white">Don't have an account?</p>
                <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-white">Create Account</a>
            </div>

             <div class="mt-3 text-center">
                <a asp-controller="Home" asp-action="Index" class="small text-white text-decoration-none">&larr; Back to Home</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}