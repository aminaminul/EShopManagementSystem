@using E_ShoppingManagement.ViewModels
@model EmployeeRegisterViewModel

@{
    ViewData["Title"] = "Employee Registration";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="register-bg">
    <div class="register-card" style="max-width: 600px;">
        <h2 class="text-center mb-4">Employee Sign Up</h2>
        <p class="text-center mb-4 opacity-75 small">Join our team</p>

        <form asp-action="EmployeeRegister" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-warning mb-3 small"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold text-white">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                <span asp-validation-for="Name" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold text-white">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label fw-bold text-white">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                <span asp-validation-for="PhoneNumber" class="text-warning small float-start"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Designation" class="form-label fw-bold text-white">Designation</label>
                    <input asp-for="Designation" class="form-control" placeholder="Designation" />
                    <span asp-validation-for="Designation" class="text-warning small float-start"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Salary" class="form-label fw-bold text-white">Salary</label>
                    <input asp-for="Salary" class="form-control" placeholder="Salary" />
                    <span asp-validation-for="Salary" class="text-warning small float-start"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold text-white">Password</label>
                <div class="position-relative password-wrapper">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                    <i class="bi bi-eye password-toggle eye-icon"></i>
                </div>
                <span asp-validation-for="Password" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-bold text-white">Confirm Password</label>
                <div class="position-relative password-wrapper">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
                    <i class="bi bi-eye password-toggle eye-icon"></i>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-warning small float-start"></span>
            </div>

            <input type="hidden" asp-for="Role" value="Employee" />

            <button type="submit" class="btn btn-register w-100 p-2 fw-bold">Register Employee</button>

            <div class="mt-3 text-center">
                <a asp-controller="Account" asp-action="Register" class="small text-light opacity-75 text-decoration-none">&larr; Back to Role Selection</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
