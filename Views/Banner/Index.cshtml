@model List<string>
@{
    ViewData["Title"] = "Manage Banners";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Manage Home Page Banners</h2>
            
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Upload New Banners</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row align-items-end">
                        <div class="col-md-8">
                            <label class="form-label">Select Images (JPG, PNG)</label>
                            <input type="file" name="bannerImages" multiple class="form-control" accept="image/*" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-cloud-upload"></i> Upload</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Existing Banners</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var img in Model)
                            {
                                <div class="col-md-4 col-lg-3">
                                    <div class="card h-100 border">
                                        <img src="/images/banners/@img" class="card-img-top" style="height: 150px; object-fit: cover;" />
                                        <div class="card-body text-center p-2">
                                            <p class="small text-muted text-truncate mb-2">@img</p>
                                            <form asp-action="Delete" method="post">
                                                <input type="hidden" name="fileName" value="@img" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Are you sure you want to delete this banner?')">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-center py-5">
                                <p class="text-muted">No banners found. Upload some to get started.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
