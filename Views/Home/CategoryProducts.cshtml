@model E_ShoppingManagement.ViewModels.CategoryProductsViewModel
@{
    ViewData["Title"] = "Explore Products";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string RenderStars(double rating) {
        int fullStars = (int)rating;
        string stars = "";
        for(int i=0; i<fullStars; i++) stars += "★";
        for(int i=fullStars; i<5; i++) stars += "☆";
        return stars;
    }
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar Filter -->
        <aside class="col-md-3">
            <div class="page-card p-3 shadow-sm border-0 sticky-top" style="top: 20px;">
                <h5 class="mb-4 border-bottom pb-2">Filter Products</h5>
                <form asp-action="CategoryProducts" method="get" id="filterForm">
                    <input type="hidden" name="query" value="@Model.SearchQuery" />
                    
                    <div class="mb-4">
                        <h6 class="mb-2">Product Categories</h6>
                        <select name="categoryId" class="form-select border-dark" onchange="this.form.submit()">
                            <option value="">All Categories</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(Model.SelectedCategory == cat.Id)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <h6 class="mb-2">Product Types</h6>
                        <select name="typeId" class="form-select border-dark" onchange="this.form.submit()">
                            <option value="">All Types</option>
                            @foreach (var type in Model.ProductTypes)
                            {
                                <option value="@type.Id" selected="@(Model.SelectedType == type.Id)">@type.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <h6 class="mb-2">Price Range</h6>
                        @{
                            var selectedPriceText = Model.PriceRange switch {
                                "low" => "Below ৳500",
                                "mid" => "৳500 - ৳2000",
                                "high" => "Above ৳2000",
                                "low-mid" => "Under ৳1500",
                                _ => "All Prices"
                            };
                        }
                        <div class="mb-2">
                             <span class="text-danger fw-bold">Selected: </span> 
                             <span class="text-dark fw-bold">@selectedPriceText</span>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="priceRange" value="low" id="p-low" onchange="this.form.submit()" @(Model.PriceRange == "low" ? "checked" : "")>
                            <label class="form-check-label fw-bold ps-1" for="p-low">Below ৳500</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="priceRange" value="mid" id="p-mid" onchange="this.form.submit()" @(Model.PriceRange == "mid" ? "checked" : "")>
                            <label class="form-check-label fw-bold ps-1" for="p-mid">৳500 - ৳2000</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="priceRange" value="high" id="p-high" onchange="this.form.submit()" @(Model.PriceRange == "high" ? "checked" : "")>
                            <label class="form-check-label fw-bold ps-1" for="p-high">Above ৳2000</label>
                        </div>
                         <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="priceRange" value="low-mid" id="p-lm" onchange="this.form.submit()" @(Model.PriceRange == "low-mid" ? "checked" : "")>
                            <label class="form-check-label fw-bold ps-1" for="p-lm">Under ৳1500</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="mb-2">Available Sizes</h6>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var s in new[] { "S", "M", "L", "XL", "XXL" })
                            {
                                <div class="form-check">
                                    <input class="form-check-input d-none" type="radio" name="size" value="@s" id="sz-@s" onchange="this.form.submit()" @(Model.SelectedSize == s ? "checked" : "")>
                                    <label class="btn btn-sm @(Model.SelectedSize == s ? "btn-primary" : "btn-outline-secondary") px-3" for="sz-@s">@s</label>
                                </div>
                            }
                        </div>
                    </div>

                    <a href="/Home/CategoryProducts" class="btn btn-outline-danger btn-sm w-100 mt-2">Clear All Filters</a>
                </form>
            </div>
        </aside>

        <!-- Product Listing -->
        <main class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4>
                    @if (!string.IsNullOrEmpty(Model.SearchQuery)) { @:Search results for "@Model.SearchQuery"
                    } else { @:Explore Products
                    }
                    <small class="text-muted fs-6">(@Model.Products.Count items found)</small>
                </h4>
            </div>

            <div class="row g-3">
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <div class="col-12 mb-3">
                        <a asp-controller="Product" asp-action="Create" class="btn btn-outline-primary btn-sm">+ Add New Product</a>
                    </div>
                }

                @foreach (var item in Model.Products)
                {
                    <div class="col-md-4 col-sm-6">
                        <div class="product-card border p-2 h-100 shadow-sm" style="transition: transform 0.2s; border-radius: 12px; position: relative;">
                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                            {
                                <div class="admin-actions position-absolute top-0 end-0 p-2 d-flex gap-1" style="z-index: 10;">
                                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-light shadow-sm" style="font-size: 10px; padding: 2px 5px;">Edit</a>
                                    <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-xs btn-danger shadow-sm text-white" style="font-size: 10px; padding: 2px 5px;">Del</a>
                                </div>
                            }

                            <a href="/Home/Details/@item.Id" style="text-decoration: none; color: inherit;">
                                <div class="image-container text-center mb-2" style="height: 150px; overflow: hidden; border-radius: 8px; background: #fdfdfd; border: 1px solid #eee;">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : (item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/images/products/" + item.ImageUrl))" 
                                         class="w-100 h-100 p-1" style="object-fit: contain;">
                                </div>
                                
                                <h6 class="mb-1 text-truncate" title="@item.Name" style="font-size: 0.9rem; font-weight: 800;">@item.Name</h6>
                                
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="price-area">
                                        @if(item.RegularPrice > item.Price) { 
                                            <span class="text-decoration-line-through text-muted extra-small me-1" style="font-size: 0.75rem;">৳@item.RegularPrice</span> 
                                        }
                                        <span class="text-danger fw-bold" style="font-size: 1rem;">৳@item.Price</span>
                                    </div>
                                    <div class="stock-badge">
                                        @if(item.StockQty > 0) {
                                            <span class="badge bg-info text-white extra-small" style="font-size: 0.7rem; padding: 3px 8px;">STOCK: @item.StockQty</span>
                                        } else {
                                            <span class="badge bg-danger text-white extra-small" style="font-size: 0.7rem; padding: 3px 8px;">EMPTY</span>
                                        }
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="text-warning small" style="font-size: 0.7rem;">@RenderStars(item.AverageRating)</div>
                                    <span class="badge @(item.Status == "Active" ? "bg-primary" : "bg-dark") text-white extra-small" style="font-size: 0.6rem; padding: 1px 5px; font-weight: 800; letter-spacing: 0.5px;">@item.Status.ToUpper()</span>
                                </div>
                            </a>

                            <div class="d-grid gap-2 mt-auto">
                                <a href="/Home/Details/@item.Id" class="btn btn-primary btn-sm">Add to Cart</a>
                                <a href="/Home/Details/@item.Id" class="btn btn-outline-danger btn-sm">Buy Now</a>
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.Products.Any())
                {
                    <div class="col-12 text-center py-5">
                        <img src="/images/no-results.png" style="width: 150px; opacity: 0.5;">
                        <p class="mt-3 text-muted">No products found matching your criteria.</p>
                    </div>
                }
            </div>
        </main>
    </div>
</div>

<style>
    .product-card:hover { transform: translateY(-5px); border-color: #6f42c1 !important; }
    .sticky-top { z-index: 1000; }
</style>
