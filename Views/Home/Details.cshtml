@model E_ShoppingManagement.Models.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var sizes = !string.IsNullOrEmpty(Model.AvailableSizes) 
        ? Model.AvailableSizes.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries) 
        : null;

    string RenderStars(double rating) {
        int fullStars = (int)rating;
        string stars = "";
        for(int i=0; i<fullStars; i++) stars += "★";
        for(int i=fullStars; i<5; i++) stars += "☆";
        return stars;
    }
}

<div class="container mt-5">
    <div class="row">
        <!-- Image Section -->
        <div class="col-md-5">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : (Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/images/products/" + Model.ImageUrl))" 
                 class="img-fluid rounded shadow-lg" alt="@Model.Name" style="max-height: 500px; width: 100%; object-fit: contain; cursor: zoom-in;" />
        </div>
        
        <!-- Details Section -->
        <div class="col-md-7">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }
            <h2>@Model.Name</h2>
            <div class="mb-2">
                <span class="text-warning fs-5">@Html.Raw(RenderStars(Model.AverageRating))</span>
                <span class="text-muted">(@Model.AverageRating.ToString("0.0"))</span>
            </div>
            <div class="price-area mb-3">
                @if (Model.OfferPercentage > 0)
                {
                    <span class="badge bg-danger mb-2">@Model.OfferPercentage% offer price</span>
                }
                <div class="d-flex align-items-center gap-2">
                    @if (Model.RegularPrice > Model.Price)
                    {
                        <h4 class="text-muted text-decoration-line-through mb-0">৳ @Model.RegularPrice</h4>
                    }
                    <h3 class="text-danger fw-bold mb-0">৳ @Model.Price</h3>
                </div>
                @if (Model.VatPercentage > 0)
                {
                    <div class="text-muted small">+ @Model.VatPercentage% VAT</div>
                }
            </div>
            
            <p class="mt-3">@Model.Description</p>
            
            <hr />
            
            <form method="get" id="addToCartForm">
                <input type="hidden" name="productId" value="@Model.Id" />
                
                @if (sizes != null && sizes.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark fs-5">Select Size:</label>
                        <div class="d-flex gap-2">
                            @foreach (var size in sizes)
                            {
                                <input type="radio" class="btn-check" name="size" id="size-@size" value="@size" required autocomplete="off">
                                <label class="btn btn-outline-dark" for="size-@size">@size</label>
                            }
                        </div>
                    </div>
                }
                
                <div class="mb-3">
                    <label class="form-label fw-bold text-dark fs-5">Quantity:</label>
                    <div class="d-flex align-items-center gap-3">
                        <input type="number" id="quantityInput" name="quantity" value="1" min="1" 
                               max="@(Math.Min(Model.StockQty, Model.MaxOrderQty > 0 ? Model.MaxOrderQty : 9999))" 
                               class="form-control border-dark" style="width: 120px; color: #000; font-weight: bold;" 
                               oninput="checkStock(this)" />
                        <span class="text-muted small">
                            (Stock: @Model.StockQty units | Max: @(Model.MaxOrderQty > 0 ? Model.MaxOrderQty.ToString() : "No Limit"))
                        </span>
                    </div>
                    <div id="stockWarning" class="text-danger small mt-1 fw-bold" style="display: none;"></div>
                </div>
                
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" formaction="/Cart/AddToCart" class="btn btn-warning text-white btn-lg px-4 shadow-sm">Add to Cart</button>
                    <button type="submit" formaction="/Cart/BuyNow" class="btn btn-danger btn-lg px-4 shadow-sm">Buy Now</button>
                    <a href="/Home/CategoryProducts?typeId=@Model.ProductTypeId" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">View More @Model.ProductType?.Name</a>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Reviews Section -->
    <div class="mt-5">
        <div class="row">
            <div class="col-md-6">
                <h4>Customer Reviews</h4>
                <div class="list-group mt-3">
                    <p class="text-muted">Recent reviews appear in the footer. Be the first to review this product!</p>
                </div>
            </div>
            <div class="col-md-6 border-start ps-4">
                <h4>Give a Review</h4>
                @{
                    var isLoggedIn = User.Identity?.IsAuthenticated ?? false;
                }
                @if (isLoggedIn)
                {
                    if (User.IsInRole("Customer"))
                    {
                        <form asp-action="SubmitReview" method="post" class="mt-3">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold" style="color: #333;">Select Rating Stars</label>
                                <select name="rating" class="form-select border-primary" style="width: 150px; background-color: #fff !important;">
                                    <option value="5">★★★★★ (5 Stars)</option>
                                    <option value="4">★★★★☆ (4 Stars)</option>
                                    <option value="3">★★★☆☆ (3 Stars)</option>
                                    <option value="2">★★☆☆☆ (2 Stars)</option>
                                    <option value="1">★☆☆☆☆ (1 Star)</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold" style="color: #333;">Write Your Comments</label>
                                <textarea name="comment" class="form-control border-primary" rows="4" placeholder="Enter your feedback here..." style="background-color: #fff !important; color: #000 !important;"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary px-5 fw-bold">Submit My Review</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info mt-3">
                            Only customers can submit reviews and ratings.
                        </div>
                    }
                }
                else
                {
                    <div class="card bg-light mt-3">
                        <div class="card-body text-center">
                            <p class="mb-2">Want to share your experience?</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-primary">Login to Give Review</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function checkStock(input) {
        const stock = @Model.StockQty;
        const maxLimit = @(Model.MaxOrderQty > 0 ? Model.MaxOrderQty : 9999);
        const val = parseInt(input.value);
        const warning = document.getElementById('stockWarning');
        
        if (val > stock) {
            warning.innerText = `Sorry, only ${stock} units are in stock.`;
            warning.style.display = 'block';
        } else if (val > maxLimit) {
            warning.innerHTML = `Maximum purchase limit is ${maxLimit} units. For bulk orders, <a href="/Home/Contact" class="text-danger fw-bold text-decoration-underline">Contact Us</a>.`;
            warning.style.display = 'block';
        } else {
            warning.style.display = 'none';
        }
    }
</script>
