@model E_ShoppingManagement.Models.DeliveryMan
@{
    ViewData["Title"] = "Edit Delivery Man";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_EmployeeLayout.cshtml";
}

<h2>Edit Delivery Man</h2>

<div class="page-card p-4" style="background: #f8f9fa; border-radius: 8px; max-width: 600px;">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="mb-3">
            <label asp-for="ContactNumber" class="form-label">Contact Number</label>
            <input asp-for="ContactNumber" class="form-control" required />
        </div>
        <div class="mb-3">
            <label asp-for="VehicleInfo" class="form-label"></label>
            <input asp-for="VehicleInfo" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-control">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
