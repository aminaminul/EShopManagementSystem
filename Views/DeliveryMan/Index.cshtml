@model IEnumerable<E_ShoppingManagement.Models.DeliveryMan>
@{
    ViewData["Title"] = "Delivery Personnel";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_EmployeeLayout.cshtml";
}

<h2 class="mb-3">Delivery Personnel</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Add New Delivery Man</a>
</div>

<div class="page-card p-3" style="background: white; border-radius: 8px;">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Vehicle</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.ContactNumber</td>
                    <td>@item.VehicleInfo</td>
                    <td><span class="badge @(item.Status == "Active" ? "bg-success" : "bg-danger")">@item.Status</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            <a asp-controller="DeliveryManDashboard" asp-action="Index" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Dashboard</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Performance</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Payments" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Payments</a>
                            }
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
