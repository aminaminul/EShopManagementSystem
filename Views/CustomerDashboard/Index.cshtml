@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <!-- Sidebar / Menu -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <img src="@(string.IsNullOrEmpty(ViewBag.ProfilePictureUrl) ? "/images/user-avatar.png" : ViewBag.ProfilePictureUrl)" class="rounded-circle mb-3 shadow-sm" style="width: 100px; height: 100px; object-fit: cover; border: 2px solid #ddd;" onerror="this.src='/images/user-avatar.png'" />
                    <h5 style="color: #333;">@ViewBag.CustomerName</h5>
                    <p class="text-muted">Verified Customer</p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/CustomerDashboard" class="list-group-item list-group-item-action active">Dashboard</a>
                    <a href="/CustomerDashboard/Profile" class="list-group-item list-group-item-action">My Profile </a>
                    <a href="/CustomerDashboard/Orders" class="list-group-item list-group-item-action">My Orders</a>
                    <a href="/Cart" class="list-group-item list-group-item-action">My Cart</a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <h2 class="mb-4">My Dashboard</h2>
            
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-white bg-primary shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">My Orders</h5>
                            <p class="card-text fs-4">@Model.Count()</p>
                        </div>
                    </div>
                </div>
                <!-- Add more cards later -->
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Recent Orders</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted">You haven't placed any orders yet.</p>
                            <a href="/" class="btn btn-outline-primary">Start Shopping</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>#@order.Id</td>
                                            <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>৳@order.TotalAmount</td>
                                            <td>
                                                <span class="badge @(order.OrderStatus == "Delivered" ? "bg-success" : (order.OrderStatus == "Cancelled" ? "bg-danger" : "bg-warning text-dark"))">
                                                    @order.OrderStatus
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/CustomerDashboard/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
