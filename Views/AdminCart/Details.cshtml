@model E_ShoppingManagement.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Cart Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Cart Details</h2>

<div class="page-card p-4" style="background: #f8f9fa; border-radius: 12px; border: 1px solid #ddd;">

    <div class="mb-4 d-flex justify-content-between">
        <h4 style="color: #333;">Customer Cart: <span style="color: #007bff;">@Model.CustomerName</span></h4>
        <span class="badge bg-secondary">Status: Active</span>
    </div>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="alert alert-light">This cart is empty.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm" style="background: white;">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 100px;">Image</th>
                        <th>Product</th>
                        <th style="width: 120px;">Unit Price</th>
                        <th style="width: 100px;">Qty</th>
                        <th style="width: 120px;">Total</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@(item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/images/products/" + item.ImageUrl)"
                                         style="width:60px;height:60px;object-fit:cover;border-radius:4px; border: 1px solid #eee;" />
                                }
                                else
                                {
                                    <div style="width:60px;height:60px;background:#eee;border-radius:4px;"></div>
                                }
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #333;">@item.ProductName</div>
                            </td>
                            <td style="color: #d9534f; font-weight: bold;">৳@item.UnitPrice</td>
                            <td><span class="badge bg-secondary">@item.Quantity</span></td>
                            <td style="font-weight: bold; color: #2c3e50;">৳@item.LineTotal</td>
                            <td>
                                <form asp-action="RemoveItem" method="post" class="d-inline">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <input type="hidden" name="cartId" value="@Model.CartId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 p-3" style="background: #eee; border-radius: 8px;">
            <div>
                <form asp-action="ClearCart" method="post">
                    <input type="hidden" name="cartId" value="@Model.CartId" />
                    <button type="submit" class="btn btn-danger btn-sm">Clear Entire Cart</button>
                </form>
            </div>
            <div style="font-size: 1.3rem; color: #333;">
                <strong>Grand Total:</strong> <span style="color: #d9534f; font-weight: bold;">৳@Model.Total</span>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary btn-sm">↩ Back to Carts</a>
    </div>
</div>
