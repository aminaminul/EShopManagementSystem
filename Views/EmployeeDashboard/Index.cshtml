@model E_ShoppingManagement.ViewModels.EmployeeStatsViewModel
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<style>
    .stat-card {
        padding: 20px;
        border-radius: 10px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .bg-inventory { background-color: #6c757d; }
    .bg-pending { background-color: #ffc107; color: #333; }
    .bg-processing { background-color: #17a2b8; }
    .bg-delivered { background-color: #28a745; }
    .bg-dm { background-color: #6f42c1; }
    .bg-active { background-color: #ef4444; }
    
    .table-container {
        background: #fdfdfd;
        padding: 20px;
        border-radius: 12px;
        margin-top: 30px;
        border: 1px solid #dee2e6;
    }
    .table-container h4 {
        color: #333;
        margin-bottom: 20px;
    }
    .quick-links .btn {
        margin-bottom: 10px;
    }
</style>

<div class="container-fluid mt-4">
    <h3 class="mb-4">💼 Employee Dashboard Overview</h3>

    <!-- KEY STATS -->
    <div class="row">
        <div class="col-md-2">
            <div class="stat-card bg-inventory">
                <h4>@Model.TotalProductsManaged</h4>
                <p class="small">My Products</p>
                <small>Qty: @Model.TotalInventoryQty</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card bg-pending">
                <h4>@Model.PendingOrders</h4>
                <p class="small">My Pending</p>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card bg-processing">
                <h4>@Model.ProcessingOrders</h4>
                <p class="small">My Processing</p>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card bg-delivered">
                <h4>@Model.DeliveredOrders</h4>
                <p class="small">My Sales</p>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card bg-dm">
                <h4>@Model.TotalDeliveryMen</h4>
                <p class="small">Total Delivery Man</p>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card bg-active">
                <h4>@Model.ActiveDeliveries</h4>
                <p class="small">Shipping Now</p>
            </div>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="row quick-links mb-4">
        <div class="col-md-12">
            <a asp-controller="EmployeeProduct" asp-action="Index" class="btn btn-primary">My Products</a>
            <a asp-controller="EmployeeOrder" asp-action="MySales" class="btn btn-success">My Sales</a>
            <a asp-controller="EmployeeProduct" asp-action="Create" class="btn btn-info">Add New Product</a>
        </div>
    </div>

    <!-- ASSIGNED ORDERS -->
    <div class="table-container">
        <h4>Recent Orders Assigned to Me</h4>
        <div class="table-responsive">
            <table class="table table-hover align-middle" style="background: white;">
                <thead class="table-dark">
                    <tr>
                        <th>SL</th>
                        <th>Ref</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Location</th>
                        <th>Action</th>
                    </tr>
                </thead>
                @{
                    int i = 1;
                }

                <tbody>
                    @foreach (var order in Model.AssignedOrders)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@order.OrderId</td>
                            <td>@order.CustomerName</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>৳ @order.Amount</td>
                            <td><span class="badge @(order.Status == "Delivered" ? "bg-success" : "bg-warning")">@order.Status</span></td>
                            <td>
                                <small>@order.PaymentStatus (@order.PaymentMethod)</small>
                            </td>
                            <td><small>@order.ShippingAddress</small></td>
                            <td>
                                <a asp-controller="EmployeeOrder" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
