@{
    ViewData["Title"] = "Logout";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm mx-auto" style="max-width: 500px;">
        <div class="card-body p-5">
            <h2 class="mb-4">Log Out</h2>
            <p class="text-muted mb-4">Are you sure you want to sign out of your account?</p>
            
            <form asp-action="Logout" method="post">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg">Yes, Log Out</button>
                    <a href="/" class="btn btn-outline-secondary btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
