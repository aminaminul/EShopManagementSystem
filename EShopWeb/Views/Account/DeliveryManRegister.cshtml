@model E_ShoppingManagement.ViewModels.DeliveryManRegisterViewModel
@{
    ViewData["Title"] = "Delivery Man Registration";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="register-bg">
    <div class="register-card" style="max-width: 600px;">
        <h2 class="text-center mb-3">Join as Delivery Man</h2>
        <p class="text-center mb-4 opacity-75 small">Register your vehicle and start delivering</p>

        <form asp-action="DeliveryManRegister" method="post">
            <div asp-validation-summary="ModelOnly" class="text-warning small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter your full name" required />
                <span asp-validation-for="Name" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="email@example.com" required />
                <span asp-validation-for="Email" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactNumber" class="form-label fw-bold">Contact Number</label>
                <input asp-for="ContactNumber" class="form-control" placeholder="017XXXXXXXX" required />
                <span asp-validation-for="ContactNumber" class="text-warning small float-start"></span>
            </div>

            <div class="mb-3">
                <label asp-for="VehicleInfo" class="form-label fw-bold">Vehicle Information</label>
                <input asp-for="VehicleInfo" class="form-control" placeholder="Bike / Van / Cycle (Plate No)" />
                <span asp-validation-for="VehicleInfo" class="text-warning small float-start"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label fw-bold">Password</label>
                    <div class="password-wrapper position-relative">
                        <input asp-for="Password" class="form-control" type="password" required />
                        <i class="bi bi-eye password-toggle eye-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-warning small float-start"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm</label>
                    <div class="password-wrapper position-relative">
                        <input asp-for="ConfirmPassword" class="form-control" type="password" required />
                        <i class="bi bi-eye password-toggle eye-icon"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-warning small float-start"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-register w-100 py-2 fw-bold mt-2">Register Now</button>
        </form>

        <div class="mt-4 text-center">
            <p class="small mb-1 opacity-75">Already have an account? <a asp-action="Login" class="fw-bold text-white text-decoration-none">Login</a></p>
            <a asp-action="Register" class="text-decoration-none small text-light opacity-75">&larr; Back to selection</a>
        </div>
    </div>
</div>
