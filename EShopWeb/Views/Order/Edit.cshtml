@model E_ShoppingManagement.Models.Order
@{
    ViewData["Title"] = "Manage Order";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var employees = ViewBag.Employees as List<E_ShoppingManagement.Models.Employee>;
    var deliveryMen = ViewBag.DeliveryMen as List<E_ShoppingManagement.Models.DeliveryMan>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Order #@Model.Id</h2>
        <a asp-controller="AdminDashboard" asp-action="OrdersByStatus" asp-route-status="@Model.OrderStatus" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="page-card p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Order Status</label>
                        <select name="orderStatus" class="form-select">
                            @foreach (var status in (List<string>)ViewBag.OrderStatuses)
                            {
                                <option value="@status" selected="@(Model.OrderStatus == status)">@status</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Payment Status</label>
                        <select name="paymentStatus" class="form-select">
                            @foreach (var pStat in (List<string>)ViewBag.PaymentStatuses)
                            {
                                <option value="@pStat" selected="@(Model.PaymentStatus == pStat)">@pStat</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-info">Assign Employee</label>
                        <select name="assignedEmployeeId" class="form-select">
                            <option value="">-- No Assignment --</option>
                            @if (employees != null)
                            {
                                foreach (var emp in employees)
                                {
                                    <option value="@emp.Id" selected="@(Model.AssignedEmployeeId == emp.Id)">@emp.Name (@emp.Email)</option>
                                }
                            }
                        </select>
                        <small class="text-muted">Select employee responsible for this order.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-success">Assign Delivery Man</label>
                        <select name="deliveryManId" class="form-select">
                            <option value="">-- No Assignment --</option>
                            @if (deliveryMen != null)
                            {
                                foreach (var dm in deliveryMen)
                                {
                                    <option value="@dm.Id" selected="@(Model.DeliveryManId == dm.Id)">@dm.Name (@dm.ContactNumber)</option>
                                }
                            }
                        </select>
                        <small class="text-muted">Select personnel for delivery.</small>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary btn-lg px-5">Save Changes</button>
            </div>
        </form>
    </div>

    <div class="mt-4">
        <h5>Quick Order Summary</h5>
        <div class="card bg-light">
            <div class="card-body">
                <p class="mb-1"><strong>Customer:</strong> @Model.Customer?.Name</p>
                <p class="mb-1"><strong>Total Amount:</strong> <span class="text-danger fw-bold">৳ @Model.TotalAmount</span></p>
                <p class="mb-0"><strong>Shipping:</strong> @Model.ShippingAddress, @Model.City</p>
            </div>
        </div>
    </div>
</div>
