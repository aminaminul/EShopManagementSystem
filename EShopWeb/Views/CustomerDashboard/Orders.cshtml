@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Orders";
}

<div class="container mt-5">
    <div class="row">
         <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                     <img src="~/images/user-avatar.png" class="rounded-circle mb-3" style="width: 100px; height: 100px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/100'" />
                    <h5>@ViewBag.CustomerName</h5>
                    <p class="text-muted">Customer</p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/CustomerDashboard" class="list-group-item list-group-item-action">Dashboard</a>
                    <a href="/CustomerDashboard/Profile" class="list-group-item list-group-item-action">My Profile</a>
                    <a href="/CustomerDashboard/Orders" class="list-group-item list-group-item-action active">My Orders</a>
                    <a href="/Cart" class="list-group-item list-group-item-action">My Cart</a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h2 class="mb-4">My Orders</h2>
            
             <div class="card shadow-sm">
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <p class="text-muted">No orders found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>@order.Id</td>
                                            <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>৳@order.TotalAmount</td>
                                            <td>
                                                <span class="badge @(order.OrderStatus == "Delivered" ? "bg-success" : (order.OrderStatus == "Cancelled" ? "bg-danger" : "bg-warning text-dark"))">
                                                    @order.OrderStatus
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/CustomerDashboard/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">View</a>
                                                @if (order.PaymentStatus == "Paid")
                                                {
                                                    <a href="/CustomerDashboard/MoneyReceipt/@order.Id" class="btn btn-sm btn-outline-success ms-1">Receipt</a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
