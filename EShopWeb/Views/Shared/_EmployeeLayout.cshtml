<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Employee</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Admin CSS (reuse same styles) -->
    <link href="~/css/admin.css" rel="stylesheet" />
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">EMPLOYEE</h4>

            <a asp-controller="EmployeeDashboard" asp-action="Index">Dashboard</a>

            <p class="menu-title">PRODUCTS & TYPES</p>
            <a asp-controller="EmployeeProduct" asp-action="Index">Manage Products</a>
            <a asp-controller="ProductType" asp-action="Index">Product Types</a>

            <p class="menu-title">ORDERS & LOGISTICS</p>
            <a asp-controller="EmployeeOrder" asp-action="Index">Manage Orders</a>
            <a asp-controller="EmployeeOrder" asp-action="Pending">Pending Orders</a>
            <a asp-controller="DeliveryMan" asp-action="Index">Delivery Personnel</a>
            <a asp-controller="Customer" asp-action="Index">Manage Customers</a>

            <p class="menu-title">PERSONAL</p>
            <a asp-controller="EmployeeOrder" asp-action="MySales">My Sales Performance</a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="Home" asp-action="Index">Back to Website</a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <!-- HEADER -->
            <header class="admin-header">
                <form asp-controller="EmployeeOrder" asp-action="Index" method="get" class="search-box">
                    <input type="text" name="query" placeholder="Search orders..." />
                    <button type="submit">??</button>
                </form>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

</body>
</html>
