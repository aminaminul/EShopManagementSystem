@model IEnumerable<E_ShoppingManagement.Models.DeliveryManPayment>
@{
    var dm = ViewBag.DeliveryMan as E_ShoppingManagement.Models.DeliveryMan;
    ViewData["Title"] = "Commission Payments - " + dm?.Name;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💰 Commissions: @dm?.Name</h2>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h5>Total Earnings</h5>
                    <h3>৳@dm?.TotalEarnings</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body text-center">
                    <h5>Total Paid</h5>
                    <h3>৳@dm?.PaidAmount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow-sm">
                <div class="card-body text-center">
                    <h5>Pending Balance</h5>
                    <h3>৳@dm?.PendingAmount</h3>
                </div>
            </div>
        </div>
    </div>

    @if (dm?.PendingAmount > 0)
    {
        <div class="card border-primary mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-primary">Process New Payout</h5>
                <form asp-action="ProcessPayout" method="post" class="row g-3">
                    <input type="hidden" name="id" value="@dm.Id" />
                    <div class="col-auto">
                        <label class="visually-hidden">Amount</label>
                        <div class="input-group">
                            <div class="input-group-text">৳</div>
                            <input type="number" name="amount" class="form-control" placeholder="Amount" step="0.01" max="@dm.PendingAmount" required>
                        </div>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary px-4">Payout Now</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Transaction History</h5>
            <small>History of commission payouts</small>
        </div>
        <div class="card-body bg-light">
             <p class="text-muted small mb-0">
                 <i class="bi bi-info-circle"></i> 
             </p>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Order #</th>
                        <th>Order Total</th>
                        <th>Commission (Earned)</th>
                        <th>Status</th>
                        <th>Paid Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td><a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId" class="text-decoration-none fw-bold">#@item.OrderId</a></td>
                            <td>৳@item.OrderTotal</td>
                            <td class="fw-bold text-success">৳@item.CommissionAmount</td>
                            <td>
                                @if(item.Status == "Paid") {
                                    <span class="badge bg-success"><i class="bi bi-check-lg"></i> Paid</span>
                                } else {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            </td>
                            <td>@(item.PaidAt?.ToString("MMM dd, yyyy") ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No commissions registered yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
