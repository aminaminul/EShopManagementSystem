@model IEnumerable<E_ShoppingManagement.Models.PaymentMethod>
@{
    ViewData["Title"] = "Payment Methods";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Payment Methods</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="page-card mb-4">
            <h5>Add New Method</h5>
            <form asp-action="AddPaymentMethod" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Method Name (e.g. bKash, Nagad)</label>
                    <input name="Name" class="form-control" required placeholder="Enter method name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Details / Instructions</label>
                    <textarea name="Details" class="form-control" rows="3" placeholder="Account number or usage details"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Logo Icon</label>
                    <input type="file" name="logoFile" class="form-control" accept="image/*" />
                </div>
                @* <input type="hidden" name="IsActive" value="true" /> *@
                <button type="submit" class="btn btn-primary w-100">Add Method</button>
            </form>
        </div>
    </div>
    <div class="col-md-8">
        <div class="page-card">
            <h5>Existing Methods</h5>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>
                                @if(!string.IsNullOrEmpty(m.LogoUrl)){
                                    <img src="@m.LogoUrl" style="height: 20px; margin-right: 10px;" />
                                }
                                <strong>@m.Name</strong>
                            </td>
                            <td><span class="badge bg-success">@m.Status</span></td>
                            <td>@m.CreatedAt.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
